# ── 数据库 (PostgreSQL) ────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:your-password@127.0.0.1:5432/pmax
DATABASE_URL_SYNC=postgresql://postgres:your-password@127.0.0.1:5432/pmax

# ── Redis (EventBus: Stream + Pub/Sub) ─────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0

# ── JWT ────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=24h

# ── 应用配置 ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── LLM ────────────────────────────────────────────────────────
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=your-llm-base-url
LLM_MODEL=your-llm-model-name

# ── 外部工具 ───────────────────────────────────────────────────
TAVILY_API_KEY=your-tavily-api-key

# ── LangSmith Observability (optional) ──────────────────────────
# 设置 LANGSMITH_TRACING=true 并提供 API key 即可自动追踪
# 所有 LLM 调用。获取 key: https://smith.langchain.com/settings
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=dagents-insightflow

+    id: "analysis_reasoning",
+    description: "对采集数据进行多维对比分析和 SWOT 生成",
+    inputHints: ["config", "rawData", "structuredData"],
+    outputHints: ["analysisResults"],
+    requires: ["information_collection"],
+    tools: [matrixTool, swotTool],

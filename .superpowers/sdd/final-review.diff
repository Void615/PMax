+              dimension: "functionality",
+              attribute: "去广告",
+              values: [{ target: "微博", value: "支持", sourceTraceId: "" }, { target: "知乎", value: "支持", sourceTraceId: "" }],
+              winner: null,
+              analysis: "两者均支持去广告",

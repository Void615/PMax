+// backend/src/api/users/dto/create-user.dto.ts
+import { IsEmail, IsString, MinLength, IsOptional } from 'class-validator';
+
+export class CreateUserDto {
+  @IsEmail()
+  email: string;
+
+  @IsString()
+  @MinLength(6)
+  password: string;
+
+  @IsString()
+  @IsOptional()
+  name?: string;
+}
+```
+
+```typescript
+// backend/src/api/users/dto/update-user.dto.ts

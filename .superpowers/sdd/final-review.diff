+              { target: "知乎", dimension: "functionality", query: "知乎 盐选 功能" },
+            ],
+          }],
+        });
+      }
+      if (prompt.includes("数据提取器")) {
+        return JSON.stringify({
+          records: [
+            { attribute: "去广告", value: "支持", confidence: 0.9 },
+            { attribute: "月费价格", value: "15元/月", confidence: 0.85 },
+          ],
+        });
+      }
+      if (prompt.includes("竞品分析师")) {
+        return JSON.stringify({
+          comparisonMatrix: [
